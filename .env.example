# === ATLAS .env example — SECURITY NOTICE ===
# Copy this file to .env and fill in real values. NEVER commit real API keys or secrets.
# Use CI/CD secret stores or Kubernetes Secrets for production credentials.

# === ATLAS Environment Example ===

# --- LLM1 (UI + RAG) ---
ATLAS_LLM1_PROVIDER=openai
ATLAS_LLM1_MODEL=gpt-4o-mini
ATLAS_LLM1_API_BASE=https://api.openai.com/v1
ATLAS_LLM1_API_KEY=
ATLAS_LLM1_FALLBACKS=mistral:mistral-small-latest,gemini:gemini-1.5-flash,ollama:llama3.1:8b-instruct

# --- LLM2 (Orchestrator, local by default) ---
ATLAS_LLM2_PROVIDER=ollama
ATLAS_LLM2_MODEL=gpt-oss:latest
ATLAS_LLM2_ALLOW_FALLBACK=false
ATLAS_LLM2_FALLBACKS=openai:gpt-4o-mini,mistral:mistral-large-latest,gemini:gemini-1.5-pro
ATLAS_LLM_TIMEOUT_MS=20000
OLLAMA_BASE_URL=http://ollama:11434

# --- LLM3 (Watcher/SecOps) ---
ATLAS_LLM3_PROVIDER=openai
ATLAS_LLM3_MODEL=gpt-4o-mini
ATLAS_LLM3_API_BASE=https://api.openai.com/v1
ATLAS_LLM3_API_KEY=
ATLAS_LLM3_FALLBACKS=gemini:gemini-1.5-flash,mistral:mistral-small-latest,ollama:llama3.1:8b-instruct

# --- MCP Servers registry ---
ATLAS_MCP_SERVERS=playwright,automation,automator,tts
ATLAS_MCP_PLAYWRIGHT_URL=http://mcp-playwright:4001
ATLAS_MCP_AUTOMATION_URL=http://mcp-automation:4002
ATLAS_MCP_AUTOMATOR_URL=http://mcp-automator:4003
ATLAS_MCP_TTS_URL=http://mcp-tts:4004
ATLAS_MCP_STT_URL=http://mcp-stt:8080

# --- TTS (mcp-tts + Coqui) ---
ATLAS_TTS_PROVIDERS=say_tts,openai_tts,elevenlabs_tts,google_tts,coqui_tts
COQUI_TTS_BASE_URL=http://coqui-tts:5002
ATLAS_TTS_AGENT_VOICE_LLM1=voiceA
ATLAS_TTS_AGENT_VOICE_LLM2=voiceB
ATLAS_TTS_AGENT_VOICE_LLM3=voiceC

# STT
ATLAS_STT_PROVIDER=whisper
ATLAS_STT_LANGUAGE=uk-UA

# Localization
ATLAS_TTS_LANG=uk
GOOGLE_TTS_LANGUAGE=uk-UA
COQUI_TTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2

# Provider keys (optional)
OPENAI_API_KEY=
ELEVENLABS_API_KEY=
GOOGLE_TTS_API_KEY=
ANTHROPIC_API_KEY=
MISTRAL_API_KEY=
GOOGLE_API_KEY=

# --- Integrations ---
LINEAR_API_KEY=
ORKES_SERVER_URL=
ORKES_API_KEY=
REDIS_URL=redis://redis:6379
QDRANT_URL=http://qdrant:6333
# Alternative: Milvus
# MILVUS_ENDPOINT=milvus:19530

# --- Phase 4 Configuration ---
ATLAS_AGENT_REGISTRY_ENABLED=true
ATLAS_TEAM_CONSTRUCTOR_ENABLED=true
ATLAS_DEBATE_MODE_ENABLED=false
ATLAS_WEB_UI_ENABLED=false

# Agent Registry
ATLAS_AGENT_REGISTRY_URL=http://agent-registry:8500
ATLAS_AGENT_REGISTRY_STORAGE=redis://redis:6379/2
ATLAS_AGENT_REGISTRY_PATH=./config/agents.json
ATLAS_AGENT_REGISTRY_PORT=8500
ATLAS_AGENT_REGISTRY_DISCOVERY_INTERVAL=30
ATLAS_AGENT_REGISTRY_HEALTH_TIMEOUT=10
ATLAS_AGENT_REGISTRY_STORAGE_BACKEND=redis

# Team Constructor
ATLAS_TEAM_MAX_SIZE=5
ATLAS_TEAM_FORMATION_TIMEOUT=30
ATLAS_TEAM_COORDINATION_MODE=event_driven
ATLAS_ROLE_TEMPLATES_PATH=./config/roles

# Example environment configuration
# Copy to .env and adjust values.

# App
PORT=3000
NODE_ENV=production

# Database (MongoDB)
# Service name todo-database is defined in compose.yaml
MONGO_URI=mongodb://todo-database:27017/todoapp

# --- Live Debate Mode ---
ATLAS_DEBATE_MODE_ENABLED=false
ATLAS_DEBATE_INTENSITY=0.5
ATLAS_DEBATE_AGGRESSION=0.2
ATLAS_DEBATE_INTERRUPT_POLICY=moderate
ATLAS_DEBATE_TURN_SECONDS=30
ATLAS_DEBATE_MAX_ROUNDS=5
ATLAS_DEBATE_MODERATOR=auto
ATLAS_DEBATE_SUMMARY_STYLE=bullets
ATLAS_DEBATE_DEVILS_ADVOCATE_RATE=0.2
ATLAS_DEBATE_STEELMAN=true
ATLAS_DEBATE_CONSENSUS_REQUIRED=soft
